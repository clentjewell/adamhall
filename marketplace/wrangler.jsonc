{
  // Cloudflare Workers config for the adamhall-marketplace service.
  // Built via @opennextjs/cloudflare — see README "Deploying".
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "adamhall-marketplace",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-05-05",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
