# Public Supabase config for client-side (browser) code.
# These NEXT_PUBLIC_* values are inlined into the JS bundle at build time so
# the browser Supabase client (saved cars, compare) works on CI/Cloudflare
# builds, which do not see the git-ignored .env.local. Both are
# publishable-by-design: the URL is public and the anon key is protected by
# Row Level Security. Do NOT put the service-role key here.
NEXT_PUBLIC_SUPABASE_URL=https://ocyxhfyphqyirjbyvhnw.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im9jeXhoZnlwaHF5aXJqYnl2aG53Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODQ1MzA2NDcsImV4cCI6MjEwMDEwNjY0N30.822fq0_iPa2qxbFZ7wrYMOyjpVt34ps2BJsvFmx2adY
