{
  // Adam Hall — Buy My Car · Brand Identity (password-gated, mirrors the BTC brand worker)
  "name": "adamhall-brand",
  "main": "src/index.js",
  "compatibility_date": "2026-07-01",
  "assets": {
    "binding": "ASSETS",
    "directory": "public",
    "html_handling": "auto-trailing-slash",
    // Required: every request must hit the password gate before assets serve.
    "run_worker_first": true
  }
}
